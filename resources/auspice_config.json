{
  "title": "CVA16 - Nextclade dataset tree",
  "build_url": "https://github.com/hodcroftlab/nextclade_a16",
  "maintainers": [
    {
      "name": "Nadia Neuner-Jehle",
      "url": "https://eve-lab.org/people/nadia-neuner-jehle/"
    },
    {
      "name": "Alejandra González-Sánchez",
      "url": "https://www.vallhebron.com/en/professionals/alejandra-gonzalez-sanchez"
    },
    {
      "name": "Emma Hodcroft",
      "url": "https://eve-lab.org/people/emma-hodcroft/"
    }
  ],  
    "extensions": {
    "nextclade": {
      "ref_nodes": {
        "default": "__root__",
        "builtins": {
          "__root__": {
            "displayName": "Static Inferred Ancestor",
            "description": "Precomputed ancestral sequence (static)"
          }
        },
        "search": [
          {
            "name": "Prototype",
            "displayName": "Reference [U05876.1]",
            "description": "Coxsackievirus A16, strain G-10",
            "criteria": [
              {
                "node": [
                  {
                    "name": ["U05876"]
                  }
                ]
              }
            ]
          },
          {
            "name": "Inferred root",
            "displayName": "Tree root",
            "description": "Inferred ancestral root (regenerated on each run)",
            "criteria": [
              {
                "node": [
                  {
                    "name": ["NODE_0000000"]
                  }
                ]
              }
            ]
          }
        ]
      }
    }
  },
  "colorings": [
    {
      "title": "Clade",
      "type": "categorical",
      "key": "clade_membership"
    },
    {
      "title": "Collection Date",
      "type": "categorical",
      "key": "date"
    },
    {
      "title": "Country",
      "type": "categorical",
      "key": "country"
    },
    {
      "title": "Global Region",
      "type": "categorical",
      "key": "region"
    }
  ],
  "geo_resolutions": [
    "country", "region"
  ],
  "filters": [
    "country",
    "region",
    "clade_membership"
  ],
  "display_defaults": {
    "color_by": "clade_membership",
    "geo_resolution": "country",
    "tip_label": "strain",
    "branch_label": "clade",
    "map_triplicate": true
  },
  "panels": [
    "tree",
    "map",
    "entropy"
  ]
}
